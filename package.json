{
  "name": "pixso-relay-server",
  "version": "0.1.0",
  "description": "A VSCode-HTTP-MCP compliant relay server in front of Pixso desktop MCP: caches root-node DSL to avoid sub-node query flakiness, sanitizes DSL output, writes get_image base64 to disk and returns a file path.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "express": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
